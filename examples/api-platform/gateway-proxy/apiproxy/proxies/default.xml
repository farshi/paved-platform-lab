<ProxyEndpoint name="default">
  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Name>Verify-JWT</Name>
      </Step>
      <Step>
        <Name>OAuthV2-Verify-Access-Token</Name>
      </Step>
      <Step>
        <Name>Quota-Per-Client</Name>
      </Step>
      <Step>
        <Name>Spike-Arrest</Name>
      </Step>
    </Request>
  </PreFlow>
  <HTTPProxyConnection>
    <BasePath>/orders/v1</BasePath>
  </HTTPProxyConnection>
  <RouteRule name="default">
    <TargetEndpoint>default</TargetEndpoint>
  </RouteRule>
</ProxyEndpoint>
